{
  "name": "@ubiquity/nofications.ubq.fi",
  "version": "1.0.0",
  "description": "The GitHub notifications viewer for UbiquityOS.",
  "main": "build/index.ts",
  "author": "Ubiquity DAO",
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx build/esbuild-server.ts",
    "start": "tsx build/esbuild-server.ts",
    "build": "tsx build/esbuild-build.ts",
    "format": "run-s format:lint format:prettier format:cspell",
    "format:lint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format:cspell": "cspell **/*",
    "knip": "knip --config .github/knip.ts",
    "knip-ci": "knip --no-exit-code --reporter json --config .github/knip.ts",
    "prepare": "husky install",
    "test": "jest --setupFiles dotenv/config --coverage"
  },
  "keywords": [
    "typescript",
    "template",
    "dao",
    "ubiquity",
    "open-source"
  ],
  "dependencies": {
    "@octokit/request-error": "^6.1.0",
    "@octokit/rest": "^20.0.2",
    "@supabase/supabase-js": "^2.39.0",
    "marked": "^11.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241011.0",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@eslint/eslintrc": "^2.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "cspell": "^8.17.5",
    "dotenv": "^16.3.1",
    "esbuild": "^0.19.8",
    "esbuild-plugin-env": "^1.0.8",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^8.0.3",
    "jest": "^29",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-localstorage-mock": "^2.4.26",
    "jest-md-dashboard": "^0.8.1",
    "jest-util": "^30.2.0",
    "knip": "^3.3.0",
    "lint-staged": "^15.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "wrangler": "^3.83.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**.{ts,json}": [
      "cspell"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
