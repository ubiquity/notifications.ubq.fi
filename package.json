{
  "name": "@ubiquity/nofications.ubq.fi",
  "version": "1.0.0",
  "description": "The GitHub notifications viewer for UbiquityOS.",
  "main": "build/index.ts",
  "author": "Ubiquity DAO",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "start": "bun build/esbuild-server.ts",
    "dev": "bun build/esbuild-server.ts",
    "build": "bun build/esbuild-build.ts",
    "format": "run-s format:lint format:prettier format:cspell",
    "format:lint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "format:cspell": "cspell **/*",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "prepare": "husky install",
    "test": "bun test"
  },
  "keywords": [
    "typescript",
    "template",
    "dao",
    "ubiquity",
    "open-source"
  ],
  "dependencies": {
    "@octokit/request-error": "^6.1.0",
    "@octokit/rest": "^20.0.2",
    "@supabase/supabase-js": "^2.39.0",
    "marked": "^11.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241011.0",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/bun": "^1.1.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "esbuild": "^0.19.8",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "@happy-dom/global-registrator": "^15.11.6",
    "typescript": "^5.3.3",
    "wrangler": "^3.83.0",
    "cspell": "^8.17.5",
    "dotenv": "^16.3.1",
    "esbuild-plugin-env": "^1.0.8"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**.{ts,json}": [
      "cspell"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
